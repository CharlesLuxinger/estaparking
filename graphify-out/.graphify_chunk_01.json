    {
      "id": "rationale_HexagonalDDD",
      "label": "Hexagonal Architecture + DDD Pattern",
      "file_type": "rationale",
      "source_file": "AGENTS.md",
      "source_location": "PLANNED ARCHITECTURE section",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Chosen to enforce strict dependency direction (infra -> domain), prevent Spring annotations leaking into domain layer, and enable testability. Detekt enforces violations as build failures."
    },
    {
      "id": "rationale_CodeQualityGates",
      "label": "Code Quality Gates (ktlint + detekt + jacoco)",
      "file_type": "rationale",
      "source_file": "AGENTS.md",
      "source_location": "CODE QUALITY GATES section",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Three-layer quality enforcement: ktlint for style (ktlint_official, 120-char lines), detekt for static analysis (custom complexity limits), jacoco for 90% coverage threshold. All have ignoreFailures=false to make CI hard-fail."
    },
    {
      "id": "rationale_NamingConventions",
      "label": "Naming Conventions (Adapters, Ports, Controllers)",
      "file_type": "rationale",
      "source_file": "AGENTS.md",
      "source_location": "PLANNED ARCHITECTURE table",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Explicit naming rules prevent ambiguity: ControllerV1 suffix for versioning, *Adapter (never *PortImpl) for infrastructure adapters, QueryPort/CommandPort for inbound ports, RepositoryPort/ClientPort for outbound ports."
    }
